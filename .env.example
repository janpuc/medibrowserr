# Every variable is optional — anything not set here can be configured in the
# Settings page instead. Values set via env are READ-ONLY in the GUI.

# SQLite database location (sqlite:// or file: URL). Defaults to ./data/medibrowserr.db
#DATABASE_URL=sqlite:///data/medibrowserr.db

# Medicover login (card number + password).
#MEDICOVER_USER=
#MEDICOVER_PASS=

# Pushover credentials (app token + user key, optional device name).
#PUSHOVER_TOKEN=
#PUSHOVER_USER=
#PUSHOVER_DEVICE=

# Defaults preselected in new monitors.
# Region/clinic ids as shown by the pickers (comma-separated), e.g. 202 = Kraków.
#MEDIBROWSERR_DEFAULT_REGION_IDS=202
#MEDIBROWSERR_DEFAULT_CLINIC_IDS=
#MEDIBROWSERR_DEFAULT_LANGUAGE=pl
#MEDIBROWSERR_DEFAULT_INTERVAL=15

# Public URL of this app; Pushover notification links point here.
#MEDIBROWSERR_URL=https://medibrowserr.example.com

# Optional built-in HTTP Basic Auth for the whole app (except /api/health).
#MEDIBROWSERR_BASIC_AUTH=user:password

# HTTP port (Next.js standard). Docker image default: 3000.
#PORT=3000

# Override the browser User-Agent sent to Medicover (empty = built-in Chrome UA).
#MEDIBROWSERR_USER_AGENT=

# Coverage index crawl pacing. The defaults (2 workers, 300 ms delay ≈ 2.5 req/s)
# are deliberately slow — faster settings have gotten IPs temporarily blocked.
#MEDIBROWSERR_SEED_CONCURRENCY=2
#MEDIBROWSERR_SEED_DELAY_MS=300

# Timezone used for schedules and displayed dates.
#TZ=Europe/Warsaw
