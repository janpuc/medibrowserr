# SQLite database location (sqlite:// or file: URL). Defaults to ./data/medibrowserr.db
#DATABASE_URL=sqlite:///data/medibrowserr.db

# Optional: seed the Medicover login on first boot (card number + password).
# You can also set these later in Settings — values entered in the UI win.
#MEDICOVER_USER=
#MEDICOVER_PASS=

# Optional: seed Pushover credentials on first boot (app token + user key).
#PUSHOVER_TOKEN=
#PUSHOVER_USER=

# Timezone used for schedules and displayed dates.
#TZ=Europe/Warsaw
